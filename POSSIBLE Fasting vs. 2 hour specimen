library(dplyr)
library(tidyr)
library(ggplot2)

# colors
colors <- c("BL" = "#003262", "INT" = "#FDB515")

# LOAD + CLEAN DATA
df_long <- read.csv("~/Desktop/Quest.csv") %>%
  mutate(across(-c(BL_INT, Participant), as.character)) %>%  # prevent type conflicts
  pivot_longer(
    cols = -c(BL_INT, Participant),
    names_to = "Variable",
    values_to = "Value"
  ) %>%
  mutate(
    Value = as.numeric(Value),
    Variable = trimws(Variable),
    Variable = gsub("\\.", " ", Variable),
    Variable = ifelse(
      Variable == "X2 HOUR SPECIMEN",
      "2 HOUR SPECIMEN",
      Variable
    )
  ) %>%
  filter(
    Variable != "BUN CREATININE RATION"
  )

# SUMMARY TABLE
df_summary <- df_long %>%
  group_by(Variable, BL_INT) %>%
  summarise(
    Mean = mean(Value, na.rm = TRUE),
    SEM  = ifelse(n() > 1, sd(Value, na.rm = TRUE) / sqrt(n()), 0),
    .groups = "drop"
  ) %>%
  filter(!is.na(Mean))

# PLOT
ggplot(df_summary, aes(x = BL_INT, y = Mean, fill = BL_INT)) +
  geom_col(width = 0.35) +
  geom_errorbar(
    aes(ymin = Mean - SEM, ymax = Mean + SEM),
    width = 0.15,
    linewidth = 0.8
  ) +
  facet_wrap(~ Variable, scales = "free_y", ncol = 4) +
  scale_fill_manual(values = colors) +
  theme_bw(base_size = 12) +
  theme(
    legend.position = "none",
    axis.text.x = element_text(angle = 0),
    strip.text = element_text(face = "bold")
  ) +
  labs(
    x = "Condition",
    y = "Mean ± SEM",
    title = "Quest CGM Data"
  )
    y = "Mean ± SEM",
    title = "Quest CGM Data"
  )
