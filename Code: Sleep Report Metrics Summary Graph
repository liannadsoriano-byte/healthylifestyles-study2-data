## Graphing Sleep Summary Metrics BL vs INT
## Made by Lianna Soriano and ChatGPT

library(tidyverse)
library(ggrepel)
library(dplyr)
library(lubridate)

#--------------------------------------------------
# LOAD DATA
setwd("C:/Users/liann/Downloads/HL2/HL2 Summary Sheets/data tables")

data <- read_csv("Sleep Summary Metrics Mean Overview - Sheet1.csv")

#--------------------------------------------------
# CLEAN DATA

data <- data %>%
  
  # split "784 INT" → ID + Timepoint
  separate(`Participant ID`, into = c("ID","Timepoint"), sep = " ") %>%
  
  # convert numbers
  mutate(across(-c(ID, Timepoint, `Sleep Onset Time (HH:MM)`, `Rise Time (HH:MM)`),
                ~as.numeric(gsub(",", "", .)))) %>%
  
  mutate(
    Timepoint = str_trim(Timepoint),
    Timepoint = str_to_upper(Timepoint),
    Timepoint = recode(Timepoint,
                       "BL" = "Baseline",
                       "INT" = "Intervention")
  ) %>%
  mutate(
    across(ends_with("(Sec)"), ~ . / 60, .names = "{.col}_min")
  ) %>%
  mutate(
    sleep_time = as.POSIXct(`Sleep Onset Time (HH:MM)`, format = "%H:%M"),
    sleep_hour = hour(sleep_time) + minute(sleep_time)/60,
    sleep_hour = ifelse(sleep_hour < 12, sleep_hour + 24, sleep_hour)
  ) %>%
  mutate(
    rise_time = as.POSIXct(`Rise Time (HH:MM)`, format = "%H:%M"),
    rise_hour = hour(rise_time) + minute(rise_time)/60,
    rise_hour = ifelse(rise_hour < 12, rise_hour + 24, rise_hour)
  ) %>%

  # remove rows without timepoint
  filter(!is.na(Timepoint)) %>%
  
  # remove rows where all variables are NA
  filter(!if_all(-c(ID, Timepoint), is.na)) %>%
  
  mutate(
    Timepoint = factor(Timepoint, levels = c("Baseline","Intervention"))
  )



#--------------------------------------------------
# SLEEP ONSET TIME GRAPH

ggplot(data, aes(x = Timepoint,
                 y = sleep_hour,
                 group = ID,
                 color = factor(ID))) +
  
  geom_line(alpha = 0.7) +
  geom_point(size = 3) +
  
  stat_summary(aes(group = 1),
               fun.data = mean_se,
               geom = "errorbar",
               width = 0.1,
               color = "black") +
  
  stat_summary(aes(group = 1),
               fun = mean,
               geom = "line",
               linewidth = 1.2,
               color = "black") +
  
  stat_summary(aes(group = 1),
               fun = mean,
               geom = "point",
               size = 3,
               color = "black") +
  
  theme_classic() +
  
  scale_y_continuous(
    limits = c(16, 26),
    breaks = 16:26,
    labels = c("16:00","17:00","18:00","19:00","20:00",
               "21:00","22:00","23:00","00:00","01:00","02:00")
  ) +
  
  labs(
    title = "Sleep Onset Time BL vs INT",
    x = "Timepoint",
    y = "Sleep Onset Time",
    color = "Participant ID"
  )

